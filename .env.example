# Copy to backend/.env and fill in values.

AZURE_API_KEY=
AZURE_OPENAI_BASE_URL=https://<resource>.cognitiveservices.azure.com/openai
AZURE_OPENAI_API_VERSION=2024-12-01-preview
AZURE_OPENAI_FILES_API_VERSION=preview
AZURE_OPENAI_DEPLOYMENT=gpt-5.4

UTILITY_MODEL_API_KEY=
UTILITY_MODEL_BASE_URL=https://<resource>.cognitiveservices.azure.com/openai
UTILITY_MODEL_API_VERSION=2024-12-01-preview
UTILITY_MODEL_DEPLOYMENT=gpt-4o

CLAUDE_AZURE_API_KEY=
CLAUDE_AZURE_FOUNDRY_ENDPOINT=https://<resource>.services.ai.azure.com/anthropic
CLAUDE_AZURE_FOUNDRY_MODEL=claude-sonnet-4-6
# Extended thinking adds load; disable if Azure returns Overloaded / 500
CLAUDE_ENABLE_THINKING=false

DATABASE_URL=postgresql://user:pass@host/db?sslmode=require
REDIS_URL=redis://default:pass@host:6379

# Fernet key for encrypting MCP credentials at rest (agents/*/mcp_servers.yaml)
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
MCP_SECRETS_KEY=

# Chat attachments — platform-wide limits (all agents share)
ATTACHMENT_MAX_FILES_PER_MESSAGE=5
ATTACHMENT_MAX_BYTES_PER_FILE=52428800
ATTACHMENT_MAX_TOTAL_BYTES_PER_MESSAGE=52428800

# Diagram rendering (agents/napkin-architect)
# PLANTUML_RENDERER=kroki   # kroki (default) or local (requires Java + PLANTUML_JAR_PATH)
KROKI_URL=https://kroki.io
# PLANTUML_JAR_PATH=tools/plantuml.jar
# PLANTUML_RENDER_TIMEOUT_SECONDS=30

# Referenced from agents/*/profile.yaml via ${VAR} (each agent picks its own names)
ODI_KNOWLEDGE_POSTGRES_URL=postgresql://user:pass@host/odi_knowledge_ai?sslmode=require

# Smart Proposal SG (agents/sg-sp-analysis/profile.yaml → mysql-mcp-server)
SG_SP_MYSQL_HOST=localhost
SG_SP_MYSQL_PORT=3306
SG_SP_MYSQL_USER=readonly_user
SG_SP_MYSQL_PASSWORD=
SG_SP_MYSQL_DATABASE=smart_proposal_sg

# Auth — cookie session (方案 A)
AUTH_DISABLED=false
AUTH_COOKIE_NAME=ap_session
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax
AUTH_SESSION_TTL_HOURS=168
